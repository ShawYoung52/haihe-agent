[common]
# ====================================================================
# 必须修改：改为你自己的路径
# ====================================================================

# MICAPS 数据根目录（包含日期子目录，如 20250820/）
rootDir=D:\micaps_data

# 省界 shapefile 路径
provincePath=D:\shp\世界国家-GB2312.shp

# 图片输出目录
saveDir=D:\output

# 绘图范围（经纬度），默认覆盖东亚
lonMin=85
lonMax=147
latMin=15
latMax=61.5

[levels]
# 各层面站点数据路径（相对于 rootDir/YYYYMMDD/）
500hPa=UPPER_AIR\PLOT\500
700hPa=UPPER_AIR\PLOT\700
850hPa=UPPER_AIR\PLOT\850

[paths]
# ====================================================================
# 位势高度场数据路径（MICAPS 14 类，包含等高线、槽线）
# ====================================================================
height_field_500=UPPER_AIR\MANUAL_ANALYSIS\HGT\500
height_field_700=UPPER_AIR\MANUAL_ANALYSIS\HGT\700
height_field_850=UPPER_AIR\MANUAL_ANALYSIS\HGT\850

# ====================================================================
# 站点观测数据路径（包含风场、露点温度）
# ====================================================================
station_data_500=UPPER_AIR\PLOT\500
station_data_700=UPPER_AIR\PLOT\700
station_data_850=UPPER_AIR\PLOT\850
