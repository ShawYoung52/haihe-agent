# Chainlit / Agent Gateway
APP_ENV=local
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8003
CHAINLIT_AUTH_SECRET=replace-with-a-long-random-secret
CHAINLIT_ADMIN_USERNAME=admin
CHAINLIT_ADMIN_PASSWORD=replace-with-a-strong-password
CHAINLIT_ENABLE_DB=1

# LLM / OpenAI-compatible endpoint
OPENAI_MODEL=Qwen3.6-27B
OPENAI_API_BASE=http://127.0.0.1:8000/v1/
OPENAI_API_KEY=replace-with-your-runtime-token
LLM_TEMPERATURE=0.7
CHAINLIT_STREAM_DELAY_MS=0.5

# MCP backend
MCP_WEATHER_URL=http://127.0.0.1:3333/sse
MCP_SERVER_URL=http://127.0.0.1:3333/sse
MCP_EXTREME_WEATHER_URL=
EXTRM_SERVER_URL=

# Chainlit history database
CHAINLIT_DB_HOST=127.0.0.1
CHAINLIT_DB_PORT=5432
CHAINLIT_DB_NAME=tjznt
CHAINLIT_DB_USER=postgres
CHAINLIT_DB_PASSWORD=replace-with-your-db-password
CHAINLIT_DB_SCHEMA=public
CHAINLIT_DB_SSLMODE=disable
CHAINLIT_DB_CONNECT_TIMEOUT=5

# River plot database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace-with-your-db-password
DB_CONNECT_TIMEOUT=5
RIVER_PLOT_PG_POOL_MAXCONN=5

# Optional CORS / deployment notes
# Configure allowed origins in Chainlit config and FastAPI middleware before production deployment.
