+def _normalize_river_name(name: Any) -> str:
+    """将单字河系名（如滦河系的“青”）规范化为“青河”。"""
+    text = str(name or "").strip()
+    if len(text) != 1:
+        return text
+    if text in ("河", "江", "湖", "海", "渠", "溪", "涧", "沟", "汊"):
+        return text
+    if "一" <= text <= "鿿":
+        return text + "河"
+    return text
