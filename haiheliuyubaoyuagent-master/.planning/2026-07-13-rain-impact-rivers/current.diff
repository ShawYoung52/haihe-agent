+                "haha": 11
+            })
+
+        sql = text(
+            f"select zonename,pre from qy_minute_zone_pre where minute_monitor_id = {hourmonitor['id']} ")
+        cursor = session.execute(sql)
+
+        zonepre = cursor.fetchall()
+
+        for item in zonepre:
+            hourmonitor["zonepre"].append({
+                "zonename": item[0],
+                "pre": item[1]
