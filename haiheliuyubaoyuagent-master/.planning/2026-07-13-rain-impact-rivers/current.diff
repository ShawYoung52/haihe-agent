+def _load_luan_name_mapping(graph_path: str | os.PathLike | None) -> dict[str, str]:
+    """加载滦河系 objectid -> 全名映射，外部 JSON 优先于内置默认。"""
+    mapping = _DEFAULT_LUAN_NAME_MAPPING.copy()
+    if not graph_path:
