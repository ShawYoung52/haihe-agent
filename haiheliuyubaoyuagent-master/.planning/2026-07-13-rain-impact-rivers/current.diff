+    try:
+        path = Path(graph_path)
+        json_path = path.parent / f"{path.stem}_luan_names.json"
+        if json_path.is_file():
+            with open(json_path, encoding="utf-8") as f:
+                mapping.update({str(k): str(v) for k, v in json.load(f).items()})
